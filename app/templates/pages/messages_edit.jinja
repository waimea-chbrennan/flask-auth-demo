{#=====================================================
  Messages edit page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>Edit Message</h2>


    <form action="/messages/edit/{{message.id}}" method="post">
      <label>
        Message Title
        <input type="text" name="title" required value="{{message.title}}">
      </label>
      <label>
        Body
        <input type="text" name="body" required value="{{message.body}}">
      </label>
      <button><i data-lucide="mail-check"></i>Update Message</button>
      <a href="/messages/delete/{{message.id}}"><button><i data-lucide="trash"></i>Delete Message</button></a>
    </form>


    

{% endblock %}