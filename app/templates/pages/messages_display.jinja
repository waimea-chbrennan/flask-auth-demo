{#=====================================================
  Messages display page
=====================================================#}

{% extends 'pages/base.jinja' %}


{% block content %}

    <h2>Messages</h2>

    
    <section id="user-messages">
        {% for message in messages%}
            <article class="user-message">
                <h3>{{message.title}}</h3>
                <p>{{message.body}}</p>
                <p>Posted By: {{message.posted_by}}</p>

                {% if message.posted_by==session["user"]["username"] or session["user"]["is_admin"]%}
                <a href="/messages/edit/{{message.id}}"><button>Edit</button></a>
                {% endif%}  
            </article>
        {% else %}
            <h3>No messages!</h3>
        {% endfor %}
    </section>

    <a href="/messages/new"><button><i data-lucide="message-square-plus"></i>New Message</button></a>
    
{% endblock %}